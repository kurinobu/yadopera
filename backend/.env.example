# Database
DATABASE_URL=postgresql://yadopera_user:yadopera_password@postgres:5432/yadopera

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
ENVIRONMENT=development
DEBUG=True

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Brevo（メール送信）・運営あて通知
# CSV代行申し込みや新規登録通知などが送られる宛先。未設定だと申し込みAPIは 503 を返す。
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@yadopera.com
BREVO_SENDER_NAME=YadOPERA
# 運営あてメールの宛先（CSV代行申し込み・管理者通知など）。送信までテストする場合は必須。
ADMIN_NOTIFICATION_EMAIL=

# Stripe（Phase 4・ローカル開発用。値は Stripe ダッシュボード・本レポの docs/Phase4/Stripe設定確認 を参照）
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MINI=
STRIPE_PRICE_ID_SMALL=
STRIPE_PRICE_ID_STANDARD=
STRIPE_PRICE_ID_PREMIUM=
STRIPE_PRICE_ID_USAGE_PER_QUESTION=
# 従量メーターのイベント名（Phase E・Stripe ダッシュボードで設定した名前と完全一致させる。例: Usage-based）
STRIPE_METER_EVENT_NAME=
